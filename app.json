{
  "expo": {
    "name": "SBA Accounts",
    "slug": "sba-audit-final",
    "version": "1.0.0",
    "owner": "jagadeesh.j",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A192F",
    "sdkVersion": "50.0.0",
    "android": {
      "package": "com.sba.audit.app",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#0A192F"
      }
    },
    "plugins": [
      ["expo-camera", { "cameraPermission": "Allow SBA to scan bills." }],
      ["expo-image-picker", { "photosPermission": "Allow SBA to save bill photos." }]
    ],
    "extra": {
      "eas": {
        "projectId": "a3540e9a-b633-4186-b5cd-318fc4a7f4b7"
      }
    }
  }
}
